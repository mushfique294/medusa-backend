# Production Environment Variables for Dokploy

# Database Configuration
DATABASE_URL=postgresql://medusa:your_password@postgres:5432/medusa?sslmode=disable
DB_USER=medusa
DB_PASSWORD=your_secure_password
DB_NAME=medusa

# Security Secrets (Generate strong random values)
JWT_SECRET=your_jwt_secret_key_here
COOKIE_SECRET=your_cookie_secret_key_here

# Environment
NODE_ENV=production
